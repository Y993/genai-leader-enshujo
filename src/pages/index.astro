---
/**
 * src/pages/index.astro
 * Top page: exam selector (GenAI Leader / ACE / ...).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { EXAMS } from '../data/exams';
import { ALL_QUESTIONS } from '../data/questions';
import { withBase } from '../lib/url';

const total = ALL_QUESTIONS.length;
const countFor = (slug: string) => ALL_QUESTIONS.filter((q) => q.examId === slug).length;
const title = 'Google Cloud 認定 演習場 — 無料問題集（日本語）';
const description = `Google Cloud 認定試験の無料・日本語練習問題集。現在 ${EXAMS.length} 試験・計${total}問を即時フィードバックで演習できます。完全無料・登録不要。`;
---
<BaseLayout title={title} description={description} path="/">
  <div class="page-hero">
    <h1 class="page-title">Google Cloud 認定<br />無料 演習場</h1>
    <p class="page-description">{description}</p>
  </div>

  <section aria-labelledby="exam-heading">
    <h2 id="exam-heading" style="font-size:var(--text-xl);font-weight:var(--weight-bold);margin-block:var(--space-8) var(--space-4);color:var(--color-grey-900);">
      試験を選ぶ
    </h2>
    <ul class="category-list">
      {EXAMS.map((e) => (
        <li>
          <a href={withBase(`/${e.slug}/`)} style="text-decoration:none;display:block;">
            <div class="card card--hover">
              <p class="cat-title">{e.titleJa}</p>
              <p class="cat-meta">{e.shortJa}・全{countFor(e.slug)}問</p>
              <p class="cat-desc">{e.tagline}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
