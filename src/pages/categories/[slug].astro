---
// Legacy redirect: /categories/<slug>/ → /genai-leader/categories/<slug>/
// GitHub Pages cannot issue 301s, so use meta refresh + canonical to retire old URLs.
import { getExam } from '../../data/exams';
import { withBase } from '../../lib/url';

export function getStaticPaths() {
  return getExam('genai-leader')!.categories.map((c) => ({
    params: { slug: c.slug },
    props: { slug: c.slug },
  }));
}

const { slug } = Astro.props;
const dest = withBase(`/genai-leader/categories/${slug}/`);
const canonical = new URL(dest, Astro.site).toString();
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${dest}`} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="noindex, follow" />
    <title>移動しました</title>
  </head>
  <body>
    <p>このページは <a href={dest}>{canonical}</a> に移動しました。</p>
  </body>
</html>
