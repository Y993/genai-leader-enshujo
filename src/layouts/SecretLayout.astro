---
/**
 * SecretLayout.astro — 購入者専用（secret slug）演習ページの最小シェル。
 * BaseLayout との違い: noindex、閉鎖済み公開ページへのリンクを一切持たない。
 */
import { withBase } from '../lib/url';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = '' } = Astro.props;
const siteName = 'GenAI Leader 演習（購入者用）';
const fullTitle = `${title} | ${siteName}`;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
  </head>
  <body>
    <header class="site-header" role="banner">
      <div class="site-header__inner">
        <span class="site-logo">GenAI Leader <span>演習</span></span>
        <p class="site-tagline">購入者向け 練習問題（全80問）</p>
      </div>
    </header>

    <main id="main-content" tabindex="-1">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="site-footer__inner">
        <p class="footer-disclaimer">
          本ページは Google / Google Cloud とは無関係の非公式の演習問題集です。
          内容の正確性は保証されず、本番試験の問題ではありません。公式教材に基づく学習用の演習です。
        </p>
        <p class="footer-copyright">
          &copy; {new Date().getFullYear()} GenAI Leader 演習. All rights reserved.
        </p>
      </div>
    </footer>
  </body>
</html>
